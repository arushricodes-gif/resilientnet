# ── AI ─────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Real-time news polling ──────────────────────────────────────────────────────
# Get a free key at https://newsapi.org (500 requests/day free tier)
# If not set, the poller runs in demo mode with simulated headlines
NEWS_API_KEY=your_newsapi_key_here

# How often to poll NewsAPI (seconds). 300 = every 5 minutes.
POLL_INTERVAL_SEC=300

# Set to 1 to disable the background poller (useful for testing)
DISABLE_POLLER=0

# ── Firebase ────────────────────────────────────────────────────────────────────
# Path to your Firebase service account JSON key file.
# Download from Firebase Console → Project Settings → Service Accounts
# If not set, the system still works — results go to /realtime/events in memory
FIREBASE_CREDS_PATH=serviceAccountKey.json
